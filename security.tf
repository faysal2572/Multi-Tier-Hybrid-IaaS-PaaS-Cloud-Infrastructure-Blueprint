# ALB Security Group (Publicly Accessible)
resource "aws_security_group" "alb" {
  name        = "alb-security-group"
  description = "Allow inbound HTTP traffic"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# Application Instances Security Group (Private)
resource "aws_security_group" "app" {
  name        = "app-security-group"
  description = "Allow inbound traffic ONLY from ALB"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port       = 80
    to_port         = 80
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id] # Least-privilege connection
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"] # Needed for updates/patching over NAT Gateway
  }
}

# Database Security Group (Isolated)
resource "aws_security_group" "db" {
  name        = "db-security-group"
  description = "Allow inbound PostgreSQL traffic ONLY from App tier"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.app.id] # Chains directly to App instances
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}